msgstr "Ignore %s, le fichier de sortie %s est un lien symbolique.\n"

#: common.c:1942
#, c-format
msgid "Skipping symbolic link %s.\n"
msgstr "Ignore le lien symbolique %s.\n"

#: common.c:1945 common.c:2040
#, c-format
